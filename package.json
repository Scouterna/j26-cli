{
	"name": "@scouterna/j26-cli",
	"version": "1.1.2",
	"description": "Local development environment CLI for J26 microservices",
	"author": "Scouterna",
	"license": "MIT",
	"keywords": [
		"j26",
		"jamboree26",
		"cli",
		"microservices",
		"local-dev"
	],
	"repository": "https://github.com/Scouterna/j26-cli",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"type": "module",
	"bin": {
		"j26": "./dist/bin/run.js"
	},
	"scripts": {
		"dev": "npm run build && node dist/bin/dev.js",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"lint": "biome check",
		"lint:fix": "biome check --write"
	},
	"files": [
		"/dist",
		"/services.yaml"
	],
	"dependencies": {
		"@inquirer/prompts": "^7.0.0",
		"@oclif/core": "^4.0.0",
		"@oclif/plugin-help": "^6.0.0",
		"@oclif/plugin-not-found": "^3.0.0",
		"arktype": "^2.2.0",
		"js-yaml": "^4.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.0.0",
		"typescript": "^5.6.0"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"oclif": {
		"bin": "j26",
		"dirname": "j26",
		"commands": {
			"strategy": "pattern",
			"target": "./dist/src/commands",
			"globPatterns": [
				"**/*.js",
				"!**/*.d.ts",
				"!**/*.test.js"
			]
		},
		"plugins": [
			"@oclif/plugin-help",
			"@oclif/plugin-not-found"
		],
		"hooks": {
			"finally": "./dist/src/hooks/finally.js"
		},
		"topicSeparator": " "
	}
}
